datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Client {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique // Mã khách hàng (e.g., GT, SCB)
  isActive  Boolean  @default(true)
  
  picName   String?  // Tên người liên hệ (PIC)
  picContact String? // Liên hệ PIC (SĐT/Email)
  address    String?  // Địa chỉ

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  packages  PremiumPackage[]
  requests  ServiceRequest[]

  ownerId   String?
  owner     User?    @relation("ClientOwner", fields: [ownerId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("Clients")
}


model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String?  // Email để nhận thông báo
  password  String
  name      String
  role      String   @default("TAS") // ADMIN, TAS, DEV
  salary    Float?   @default(0) // Lương tháng (VNĐ)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedRequests ServiceRequest[] @relation("Assignee")
  createdRequests  ServiceRequest[] @relation("Creator")
  ownedClients     Client[]         @relation("ClientOwner")
  workLogs         WorkLog[]
  attachments      Attachment[]
  auditLogs        AuditLog[]
  notifications    Notification[]   @relation("UserNotifications")

  @@map("Users")

}

model PremiumPackage {
  id          String   @id @default(cuid())
  name        String
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  validFrom   DateTime
  validTo     DateTime
  isActive    Boolean  @default(true)
  monthlyQuota Int     @default(0) // Tổng số giờ định mức mỗi tháng
  monthlyPrice Float   @default(0) // Giá gói mỗi tháng (VNĐ)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sroRules    SRORule[]
  requests    ServiceRequest[]
  slaTargets  SlaTarget[]

  @@map("PremiumPackages")
}

model SRORule {
  id              String         @id @default(cuid())
  packageId       String
  package         PremiumPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  
  taskName        String         // Tên nghiệp vụ (e.g., Update Content, Fix Bug)
  estimateHours   Float          // Số giờ quy đổi (e.g., 0.5, 1.0)
  requestsPerMonth Float         @default(1.0) // Số lần yêu cầu định mức mỗi tháng (Float hỗ trợ số lẻ 0.33 cho 1/quý)
  scope           String?        // Phạm vi
  exclusions      String?        // Ngoại trừ
  notes           String?        // Ghi chú bán hàng linh hoạt (VD: 1 per quarter)
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  requestItems    ServiceRequestItem[]

  @@map("SRORules")
}

model ServiceRequest {
  id             String         @id @default(cuid())
  code           String         @unique // Mã tự sinh (e.g., PREM-GT-001)
  
  clientId       String
  client         Client         @relation(fields: [clientId], references: [id], onUpdate: NoAction)
  
  packageId      String
  package        PremiumPackage @relation(fields: [packageId], references: [id], onUpdate: NoAction)
  
  items          ServiceRequestItem[]
  subTasks       SubTask[]
  
  title          String         // Tiêu đề ngắn
  userRequirement String?        // Yêu cầu từ phía khách hàng (Nghiệp vụ)
  description    String         // Mô tả kỹ thuật chi tiết (Technical)
  status         String    @default("TODO") // TODO, IN_PROGRESS, DONE
  version        Int       @default(1)
  type           String    @default("TASK") // TASK, BUG, FEATURE, URGENT
  priority       String    @default("P4") // P1, P2, P3, P4
  taskPriority   String?   @default("MEDIUM") // HIGH, MEDIUM, LOW
  urgency        String?   // IMMEDIATE, URGENT, MODERATE, STANDARD
  impact         String?   // WIDESPREAD, LARGE, LIMITED, LOCALISED
  deadline       DateTime?
  agreedFinalSolution DateTime?
  estimatedTimeline   DateTime?
  assigneeId     String?   // User ID or name
  assigneeIds    String?   // Multi-select assignee user IDs, comma separated
  assignee       User?     @relation("Assignee", fields: [assigneeId], references: [id], onUpdate: NoAction)
  
  escalation     String    @default("Fujifilm business innovation vietnam support personnel")
  emailSubject   String?
  
  createdById    String?
  creator        User?     @relation("Creator", fields: [createdById], references: [id], onUpdate: NoAction, onDelete: NoAction)
  
  raiseDate      DateTime  @default(now())
  
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  comments       Comment[]
  workLogs       WorkLog[]
  attachments    Attachment[]
  auditLogs      AuditLog[]
  slaUpdateEntries SlaUpdateEntry[]
  slaLines       SlaLine[]
  
  @@index([clientId])
  @@index([packageId])
  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([assigneeId])
  @@index([raiseDate])
  @@map("ServiceRequests")
}

model ServiceRequestItem {
  id           String         @id @default(cuid())
  requestId    String
  request      ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  
  sroRuleId    String
  sroRule      SRORule        @relation(fields: [sroRuleId], references: [id], onUpdate: NoAction)
  
  note         String?        // Ghi chú riêng cho item này
  quantity     Int            @default(1) // Số lượng SRO cùng loại trong 1 request
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  workLogs     WorkLog[]

  @@map("ServiceRequestItems")
}

model SubTask {
  id          String   @id @default(cuid())
  requestId   String
  request     ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  content     String   // Tiêu đề/Nội dung chính
  description String?  // Mô tả chi tiết cho Dev
  status      String   @default("TODO") // TODO, IN_PROGRESS, DONE
  isDone      Boolean  @default(false)
  workLogs    WorkLog[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([requestId])
  @@index([status])
  @@map("SubTasks")
}

model Comment {
  id          String   @id @default(cuid())
  requestId   String
  request     ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  content     String   
  authorName  String   // Tên người bình luận
  userEmail   String?  // Email người bình luận (dùng để lọc thông báo)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("Comments")
}

model Board {
  id          String   @id @default(cuid())
  name        String
  icon        String   @default("LayoutGrid")
  filterType  String?  // TASK, BUG, etc.
  filterClient String? // Client ID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("Boards")
}

model KanbanColumn {
  id        String   @id @default(cuid())
  title     String   // Tên hiển thị (vd: Cần làm)
  statusKey String   @unique // Mã trạng thái (vd: TODO)
  color     String   @default("#94a3b8") // Màu sắc của cột
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("KanbanColumns")
}

model EmailSetting {
  id          String   @id @default("SYSTEM_CONFIG")
  host        String   // SMTP Server (e.g., smtp.gmail.com)
  port        Int      @default(587)
  secure      Boolean  @default(false)
  user        String   // Username/Email
  password    String   // SMTP Password (App Password)
  fromEmail   String   // Email gửi đi
  fromName    String   // Tên hiển thị người gửi
  
  updatedAt   DateTime @updatedAt

  @@map("EmailSettings")
}

model WorkLog {
  id          String   @id @default(cuid())
  requestId   String
  request     ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  
  subTaskId   String?
  subTask     SubTask? @relation(fields: [subTaskId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  serviceRequestItemId String?
  serviceRequestItem   ServiceRequestItem? @relation(fields: [serviceRequestItemId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  
  hours       Float
  description String?  
  logDate     DateTime @default(now())
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  groupId     String?  
  
  @@index([requestId])
  @@index([userId])
  @@index([logDate])
  @@index([groupId])
  @@map("WorkLogs")
}

model Attachment {
  id        String   @id @default(cuid())
  filename  String
  url       String
  fileType  String?
  size      Int?
  data      Bytes?   @db.ByteA
  
  requestId String
  request   ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  
  createdAt DateTime @default(now())

  @@map("Attachments")
}
 
model AuditLog {
  id        String   @id @default(cuid())
  requestId String
  request   ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  
  action    String   // e.g., "UPLOAD_EVIDENCE", "DELETE_EVIDENCE", "UPDATE_STATUS", "UPDATE_INFO"
  details   String?  // JSON or text description of the change
  
  createdAt DateTime @default(now())
 
  @@index([requestId])
  @@index([userId])
  @@index([createdAt])
  @@map("AuditLogs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   // Người nhận thông báo
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  
  title     String
  message   String   
  type      String   // e.g., "ASSIGNMENT", "STATUS_CHANGE", "COMMENT"
  link      String?  // Đường dẫn tới request/task liên quan
  isRead    Boolean  @default(false)
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("Notifications")
}

model GlobalSettings {
  id                    String   @id @default("system")
  standardMonthlyHours  Int      @default(176)
  revenueMode           String   @default("PACKAGE") // PACKAGE or SRO_HOURS
  revenuePerSroHour     Float    @default(0)
  
  // === Working Hours Config ===
  workStartTime         String   @default("08:30")     // HH:mm format
  workEndTime           String   @default("18:00")     // HH:mm format
  workDays              String   @default("1,2,3,4,5") // 0=Sun,1=Mon..5=Fri,6=Sat

  updatedAt             DateTime @updatedAt

  @@map("GlobalSettings")
}

model Holiday {
  id          String   @id @default(cuid())
  date        DateTime @unique // The holiday date
  name        String            // Holiday name (e.g., "National Day")
  year        Int               // Year for quick filtering
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([year])
  @@map("Holidays")
}

model SlaUpdateEntry {
  id                        String   @id @default(cuid())
  requestId                 String
  request                   ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  customerResponseDateTime  DateTime?  // When customer responded (nullable)
  updateDateTime            DateTime   // When team provided update
  actualUpdateFrequency     Float?     // Working hours calculated (editable override)
  note                      String?    // Free-text note

  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([requestId])
  @@map("SlaUpdateEntries")
}

model SlaTarget {
  id                    String   @id @default(cuid())
  packageId             String
  package               PremiumPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  priority              String   // P1, P2, P3, P4
  ticketType            String   // INCIDENT, PROBLEM, SRO, NSRO, OTHERS, HEALTH_CHECK
  ackTargetHours        Float    // Target hours for acknowledgement
  responseTargetHours   Float    // Target hours for response
  updateFreqTargetHours Float?   // Target hours for update frequency (incident/problem)
  completionTargetHours Float?   // Target hours for service restoration/completion

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([packageId, priority, ticketType])
  @@map("SlaTargets")
}

model SlaLine {
  id                    String   @id @default(cuid())
  requestId             String
  request               ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  
  title                 String   // Description or title of this SLA line
  priority              String   @default("P4") // P1, P2, P3, P4
  ticketType            String   @default("SRO") // INCIDENT, PROBLEM, SRO, etc.

  // === SLA: Acknowledgement ===
  ticketRequestDateTime DateTime?
  ackDateTime           DateTime?
  actualAckTime         Float?
  ackSlaTarget          Float?

  // === SLA: Response ===
  responseDateTime      DateTime?
  actualResponseTime    Float?
  responseSlaTarget     Float?

  // === SLA: Update Frequency ===
  customerResponseDateTime DateTime?
  updateDateTime           DateTime?
  actualUpdateFrequency    Float?
  updateFreqSlaTarget      Float?
  updateNote               String?

  // === SLA: Completion / Final Solution ===
  agreedFinalSolutionDateTime DateTime?
  resolutionStatus            String?
  completionDateTime          DateTime?
  actualCompletionTime        Float?
  completionSlaTarget         Float?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([requestId])
  @@map("SlaLines")
}
